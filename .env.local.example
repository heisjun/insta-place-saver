# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# 카카오맵
NEXT_PUBLIC_KAKAO_MAP_KEY=xxx         # JavaScript SDK 앱 키 (클라이언트)
KAKAO_REST_API_KEY=xxx                # REST API 키 (서버 전용)

# Anthropic (Claude)
ANTHROPIC_API_KEY=xxx

# Instagram 크롤링용 (본인 계정에서 추출)
# 추출 방법: Chrome → instagram.com 로그인 → F12 → Network 탭
# → 아무 요청 클릭 → Request Headers에서 Cookie / X-Ig-App-Id 복사
INSTAGRAM_COOKIE=xxx
INSTAGRAM_X_IG_APP_ID=xxx
